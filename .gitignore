# ── taxonomy_agent run outputs ─────────────────────────────────────────────
# Streamlit's default output directory.
taxonomy_runs/
# Ad-hoc per-project output dirs.
results/
# Bundled example regenerates these on every run.
example/out/
# Legacy SQLite checkpoints (the checkpointer was removed; old files would only
# confuse future contributors).
*.sqlite
*.sqlite3

# Streamlit secrets file (must never be committed).
.streamlit/secrets.toml

# Eval artifacts (LLM outputs, regenerable)
eval_runs/
eval_data/hybrid_build/
eval_data/cot_candidates.jsonl
eval_data/cot_patterns_hybrid.jsonl
eval_data/*_with_advice.jsonl.bak
eval_data/*_pre_repair.jsonl.bak
eval_data/*_pre_anon.jsonl.bak

# Unauthorized advice-prompt corpus from a prior session.
eval_data/advice_prompts.jsonl

# Vendor zip dropped on the project root; the unpacked acl.sty and
# acl_natbib.bst live under paper/ and are tracked.
Association_for_Computational_Linguistics__ACL__conference.zip

# LaTeX intermediates from local Overleaf-mirror compiles.
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
# Compiled PDFs, the plaintext export, and the submission tarball are all
# regenerated from the LaTeX sources; keep them out of the repo. (Tracked
# data logs under paper/data/*.txt are unaffected by these top-level globs.)
paper/*.pdf
paper/*.tar.gz
paper/paper_draft.txt
